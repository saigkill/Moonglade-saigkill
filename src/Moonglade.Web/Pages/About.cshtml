@page "/about"
@using Microsoft.AspNetCore.Mvc.Localization
@using Microsoft.AspNetCore.Mvc.TagHelpers
@using Moonglade.Data.ExternalAPI.GitHub
@using Moonglade.Data.ExternalAPI.GitHub.Models
@using Newtonsoft.Json
@using RestSharp
@inject Moonglade.Data.DataProviders.PublicationProvider _pubs
@inject IViewLocalizer _localizer
@{
    var ghRepos = new UserRepos(BlogConfig);
    string ghProfile = BlogConfig.SocialProfileSettings.GitHub;
    string ghUser = ghProfile.Replace("https://github.com/", "");
    string endpoint = $"/users/{ghUser}/repos";
    var ghResponse = ghRepos.SendRequest(Method.GET, endpoint, "");
    List<UserReposResponse.Root> repoList = JsonConvert.DeserializeObject<List<UserReposResponse.Root>>(ghResponse.Content);
}
@section head {
    <environment include="Development">
        <link rel="stylesheet" href="~/css/about.min.css" />
        <link href="https://cdn.jsdelivr.net/npm/@@fortawesome/fontawesome-free@6.2.1/css/all.css" rel="stylesheet" />
    </environment>
    <environment exclude="Development">
        <link rel="stylesheet" href="~/css/about.css" />
        <link href="https://cdn.jsdelivr.net/npm/@@fortawesome/fontawesome-free@6.2.1/css/all.min.css" rel="stylesheet" />
    </environment>
}

@section scripts {
    <environment include="Development">
        <script src="~/js/app/about.js"></script>
    </environment>
    <environment exclude="Development">
        <script src="~/js/app/about.min.js"></script>
    </environment>
}
<div class="sec pt-4">
    <div class="container">
        <h3>@_localizer["Me and the Blog"]</h3>
        <hr />
        <div class="row">
            <div class="col-md-7">
                <section id="self-intro">
                    <blockquote class="blockquote">
                        <p>
                            @_localizer["intro"]
                        </p>
                        <img src="https://github-readme-stats-ten-gilt.vercel.app/api?username=saigkill" />
                    </blockquote>
                    @*<div>
                    <a href="https://github.com/saigkill" class="btn btn-outline-success" target="_blank">
                    <span class="icon-github"></span>
                    GitHub
                    </a>
                    </div>*@
                </section>
            </div>
            <div class="col-md-5">
                <div class="center-align">
                    <img class="img-fluid img-thumbnail" width="45%" src="https://moongladestorage722.blob.core.windows.net/moongladeimages722/blog/Sascha1.jpg" />
                    <img class="img-fluid img-thumbnail" width="45%" src="https://moongladestorage722.blob.core.windows.net/moongladeimages722/blog/coat-of-arms.png" />
                </div>
            </div>
        </div>
    </div>
</div>

<div class="sec">
    <h4 class="center-text"><@_localizer["connect-header"]</h4>
    <partial name="Shared/_SocialProfiles" />
</div>


<div class="sec">
    <h4 class="center-text">@_localizer["publications"]</h4>
    @foreach (var pub in _pubs.Get())
    {
        <div tabindex="0" class="e-card" id="@pub.Id">
            <div class="card-header">
                <div class="e-card-header-caption">
                    <h4 class="card-subtitle"><a href="@pub.Link" target="_blank" class="">@pub.Title</a></h4>
                </div>
            </div>
            <div class="e-card-content">

                <div class="card-text"><small>@pub.Authors</small></div>
                <div class="card-text"><small>@pub.PublicationName - @pub.Publisher</small></div>
                @if (!string.IsNullOrWhiteSpace(pub.Identifier))
                {
                    <div class="muted"><small>@pub.Identifier, @_localizer["publisher-published"]: <time datetime="@pub.DatePublished">@pub.DatePublished</time></small></div>
                }
                else
                {
                    <div class="muted"><small>@_localizer["publisher-published"]: @pub.DatePublished</small></div>
                }
            </div>
        </div>
    }
</div>

<div class="sec">
    <h4 class="center-text">@_localizer["opensource"]</h4>
    @foreach (var repo in repoList)
    {
        <div tabindex="0" class="e-card" id="@repo.id">
            <div class="card-header">
                <div class="e-card-header-caption">
                    <h4 class="card-subtitle"><a href="@repo.git_url" target="_blank" class="">@repo.name</a></h4>
                </div>
            </div>
            <div class="e-card-content">
                <div class="card-text">@repo.description</div>
                <div class="muted"><small>@_localizer["last-updated"]: <time datetime="@repo.updated_at">@repo.updated_at</time></small></div>
            </div>
        </div>
    }
</div>