@model Moonglade.Web.Pages.PostModel

<meta name="twitter:card" content="summary" />
<meta name="twitter:title" content="@Model.Post.Title" />
<meta name="twitter:description" content="@Model.Post.ContentAbstract" />
@if (Model.Post.HeroImageUrl != null)
{
    <meta name="twitter:image" content="@Model.Post.HeroImageUrl" />
}
<meta name="twitter:creator" content="@@ghUserFix" />
